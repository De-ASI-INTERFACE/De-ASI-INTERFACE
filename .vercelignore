# .vercelignore — files excluded from Vercel deployment bundle

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env

# Tests — not needed at runtime
tests/
.pytest_cache/
.coverage
htmlcov/

# Dev tooling
.mypy_cache/
.ruff_cache/
.github/
docs/
scripts/

# Secrets — never bundle
.env.railway
.env.local
.env.*.local

# Git
.git/
.gitignore

# Node (if any frontend tooling)
node_modules/
.next/
